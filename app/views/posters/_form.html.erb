<%= form_with(model: poster, class: "contents") do |form| %>
  <% if poster.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(poster.errors.count, "error") %> prohibited this poster from being saved:</h2>

      <ul class="list-disc ml-6">
        <% poster.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :campaign_id %>
    <%= form.text_field :campaign_id, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": poster.errors[:campaign_id].none?, "border-red-400 focus:outline-red-600": poster.errors[:campaign_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :lat %>
    <%= form.text_field :lat, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": poster.errors[:lat].none?, "border-red-400 focus:outline-red-600": poster.errors[:lat].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :long %>
    <%= form.text_field :long, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": poster.errors[:long].none?, "border-red-400 focus:outline-red-600": poster.errors[:long].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :url %>
    <%= form.text_field :url, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": poster.errors[:url].none?, "border-red-400 focus:outline-red-600": poster.errors[:url].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
